    "feat = list(indicadores.values())\n",
    "gv = g.dropna(subset=feat).copy()\n",
    "\n",
    "X   = StandardScaler().fit_transform(gv[feat])\n",
    "pca = PCA(n_components=1).fit(X)\n",
    "pc1 = pca.transform(X)[:, 0]\n",
    "# Orientar para que MAYOR = MAYOR rezago\n",
    "if np.mean(pca.components_[0]) < 0:\n",
    "    pc1 = -pc1\n",
    "gv[\"idx_rezago\"] = pc1\n",
    "g = g.merge(gv[[\"CVEGEO\", \"idx_rezago\"]], on=\"CVEGEO\", how=\"left\")\n",
    "\n",
    "print(f\"Varianza explicada por el 1er componente: {pca.explained_variance_ratio_[0]*100:.1f}%\")\n",
    "cargas = pd.Series(pca.components_[0] * (1 if np.mean(pca.components_[0])>=0 else -1),\n",
    "                   index=feat).sort_values(ascending=False)\n",
    "print(\"\\nCargas del componente (mayor = más asociado a rezago):\")\n",
    "print(cargas.round(3))"
   ]
