    "def quitar_acentos(s):\n",
    "    if pd.isna(s): return s\n",
    "    return \"\".join(c for c in unicodedata.normalize(\"NFKD\", str(s))\n",
    "                   if not unicodedata.combining(c)).upper().strip()\n",
    "\n",
    "ti = pd.read_csv(ARCHIVO_TIANGUIS, encoding=\"utf-8\")\n",
    "n0 = len(ti)\n",
    "ti[\"alcaldia\"] = ti[\"alcaldia\"].apply(quitar_acentos)\n",
    "ti[\"latitud\"]  = pd.to_numeric(ti[\"latitud\"],  errors=\"coerce\")\n",
    "ti[\"longitud\"] = pd.to_numeric(ti[\"longitud\"], errors=\"coerce\")\n",
    "\n",
    "# Rectángulo geográfico aproximado de la CDMX\n",
    "BBOX = dict(lat=(19.0, 19.65), lon=(-99.40, -98.90))\n",
    "ok = (ti[\"latitud\"].between(*BBOX[\"lat\"]) & ti[\"longitud\"].between(*BBOX[\"lon\"]))\n",
    "print(f\"Tianguis en el archivo original : {n0}\")\n",
    "print(f\"Descartados (coord. inválida)   : {(~ok).sum()}\")\n",
    "ti = ti[ok].copy()\n",
    "print(f\"Tianguis válidos                : {len(ti)}\")\n",
    "\n",
    "# GeoDataFrame de puntos\n",
    "gti = gpd.GeoDataFrame(ti, geometry=gpd.points_from_xy(ti[\"longitud\"], ti[\"latitud\"]),\n",
    "                       crs=CRS_GEO)\n",
    "gti.head(3)"
